						"title<.*youtube.*>": "п…Ә", // Windows whose titles contain "youtube"
						"class<.*qutebrowser.*>": "пүЁ ", // Windows whose classes are "qutebrowser"
						"class<qutebrowser> title<.*github.*>": "п„“",
						"class<com.mitchellh.ghostty>": "п„ ",
						"class<emacs>": "пҳЎ",
						"class<rstudio>": "п“·",
						"class<libreoffice-.*>": "п•і",
						"code": "п„Ў",
				},
		},
		"hyprland/window": {
				"max-length": 40,
				"min-length": 5,
				"rewrite": {
						"(.*) - Vivaldi": "пүЁ  $1",
						"(.*) - Emacs": "п„Ў $1",
						"(.*) - Anki": "пҖӯ $1",
						"Zellij \\((.*)\\) - (.*)": "п„  $1 - $2",
						"(.*) - Libreoffice Calc": "пҮғ $1",
						"(.*) - Libreoffice Writer": "пҮӮ $1",
						"(.*) - Libreoffice Impress": "пҮ„ $1"
				},
				"separate-outputs": false
		},
		"hyprland/workspaces": {
				"format": "{icon}",
				"format-icons": {
						"1": "<span color=\"#D8DEE9\">еЈ№</span>",
						"2": "<span color=\"#D8DEE9\">иҙ°</span>",
						"3": "<span color=\"#D8DEE9\">еҸҒ</span>",
						"4": "<span color=\"#88C0D0\">иӮҶ</span>",
						"5": "<span color=\"#A3BE8C\">дјҚ</span>",
						"6": "<span color=\"#D8DEE9\">йҷҶ</span>",
						"7": "<span color=\"#D8DEE9\">жҹ’</span>",
						"8": "<span color=\"#D8DEE9\">жҚҢ</span>",
						"9": "<span color=\"#D8DEE9\">зҺ–</span>",
						"10": "<span color=\"#D8DEE9\">жӢҫ</span>",
