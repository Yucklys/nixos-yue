						"focused": "п„‘",
						"default": "п„Ң"
				},
				"all-outputs": false,
				"current-only": false,
		},
		"niri/window": {
				"separate-outputs": true,
		},
		"idle_inhibitor": {
				"format": "{icon}",
				"format-icons": {
