{
		"bluetooth": {
				"format": "{icon}",
				"format-icons": {
						"disabled": "пҡ”",
						"enabled": "пҠ“"
				},
				"interval": 30,
				"on-click": "blueman-manager"
		},
		"battery": {
				"interval": 60,
				"states": {
						"warning": 30,
						"critical": 15
				},
				"format": "{icon}",
				"format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"],
				"tooltip-format": "{capacity}%, {timeTo}",
				"max-length": 25
		},
		"clock": {
				"format": "пҖ— {:%H:%M пҒі %e %b}",
				"on-click": "gnome-calendar",
				"today-format": "<b>{}</b>",
				"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
		},
		"cpu": {
				"format": "п’ј {max_frequency}GHz/<span color=\"#a6adc8\">{usage}%</span>",
				"interval": 1,
				"max-length": 15,
				"min-length": 15,
				"on-click": "ghostty -e 'htop --sort-key PERCENT_CPU'",
				"tooltip": false
		},
		"hyprland/language": {
				"format": "<big>п•ҫ</big> {}",
				"max-length": 25,
				"min-length": 5
		},
		"hyprland/workspaces": {
				"format": "{icon}",
				"format-icons": {
						"1": "еЈ№",
						"2": "иҙ°",
						"3": "еҸҒ",
						"4": "иӮҶ",
						"5": "дјҚ",
						"6": "йҷҶ",
						"7": "жҹ’",
						"8": "жҚҢ",
						"9": "зҺ–",
				},
				"window-rewrite-default": "п„‘",
