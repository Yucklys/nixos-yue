						"deactivated": "пҒ°"
				},
				"max-length": 5,
				"min-length": 2,
				"tooltip": true
		},
		"network": {
				"family": "ipv4",
				"format-alt": "{ifname}: {ipaddr}/{cidr}",
				"format-disconnected": "у°–Ә",
				"format-ethernet": "{ifname}: {ipaddr}/{cidr} пһ–",
				"format-linked": "{ifname} (No IP) пһ–",
				"format-wifi": "пҮ«",
				"tooltip-format-ethernet": "пһ– {ifname}\nIP: {ipaddr}\nпҚ— {bandwidthUpBits} пҚ” {bandwidthDownBits}",
				"tooltip-format-wifi": "пҮ«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nпҚ— {bandwidthUpBits} пҚ” {bandwidthDownBits}"
		},
		"pulseaudio": {
				"format": "{icon} {volume}%",
				"format-icons": {
						"car": "пҶ№",
						"default": [
								"пҖҰ",
								"пҖ§",
								"пҖЁ"
						],
						"hands-free": "п–җ",
						"headphone": "пҖҘ",
						"headset": "п–җ",
						"phone": "пӮ•",
						"portable": "пӮ•"
				},
				"format-muted": "пҡ©",
				"format-source-muted": "у°Қӯ",
				"on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
				"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
				"scroll-step": 3
		},
		"temperature": {
				"critical-threshold": 74,
				"format": "{icon} {temperatureC}В°C",
				"format-critical": "пҒұ {temperatureC}В°C",
				"format-icons": [
						"пӢӢ",
						"пӢү",
						"пӢҮ"
				],
				"interval": 4,
				"max-length": 7,
				"min-length": 7
		},
		"tray": {
				"spacing": 5
		},
		"mpd": {
				"format": "{artist} - {title} пҒӢ",
